# ============================================================
# GoMiGo Environment Variables
# ============================================================
# REQUIRED: Only 3 env vars needed to boot the application.
# All other config (Razorpay, WhatsApp, email, etc.) is stored
# in the platform_settings DB table and configured via /admin/setup
# ============================================================

# === Supabase (REQUIRED) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Database Direct Connection (for Drizzle migrations) ===
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# === App URL ===
NEXT_PUBLIC_APP_URL=https://your-domain.com

# === Environment ===
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ============================================================
# OPTIONAL: Override platform_settings table values via ENV
# These take precedence over DB settings when set
# ============================================================

# Razorpay (optional - configure via /admin/setup instead)
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...

# WhatsApp - Wati.io (optional)
# WATI_API_ENDPOINT=https://live-server.wati.io
# WATI_ACCESS_TOKEN=...

# WhatsApp - Meta Cloud API fallback (optional)
# META_WHATSAPP_TOKEN=...
# META_PHONE_NUMBER_ID=...

# Email SMTP (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# EMAIL_FROM=noreply@yourdomain.com

# SMS - MSG91 (optional)
# MSG91_AUTH_KEY=...
# MSG91_TEMPLATE_ID=...

# Maps (optional - falls back to straight-line calculation)
# OPENROUTESERVICE_API_KEY=...

# Cloudflare R2 storage (optional - uses Supabase Storage by default)
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=gomigo-uploads

# ============================================================
# DEVELOPMENT ONLY
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (from supabase start output)
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (from supabase start output)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
